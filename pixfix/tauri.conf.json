{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/refs/heads/main/.github/schema/tauri-conf.schema.json",
  "productName": "pixfix",
  "version": "0.1.0",
  "identifier": "com.pixfix.app",
  "build": {
    "frontendDist": "./ui",
    "beforeDevCommand": "bun build pixfix/ui/src/app.ts --outfile pixfix/ui/app.js --sourcemap=inline",
    "beforeBuildCommand": "bun build pixfix/ui/src/app.ts --outfile pixfix/ui/app.js --minify"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "pixfix",
        "width": 1100,
        "height": 750,
        "maximized": true,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' blob: data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
